Non_LPS_matrix <- as.matrix(Non_LPS [, 12:21])
head(Non_LPS_matrix)
hist(Non_LPS_matrix) #includes everything

#natural log transform the matrix
Non_LPS_LN <- log(Non_LPS_matrix)
head(Non_LPS_LN)
